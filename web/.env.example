# === Required ===
# Server-side only. Never expose to client.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# === Models (have sensible defaults) ===
# Cheap default for free tier
CLAUDE_MODEL_FREE=claude-haiku-4-5-20251001
# Premium for paid tier
CLAUDE_MODEL_PAID=claude-sonnet-4-6

# === Rate limiting (optional - falls back to in-memory if absent) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Conversion ===
NEXT_PUBLIC_WECHAT_QR_URL=/wechat-qr.png
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# === Analytics (optional) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Free quota ===
FREE_MESSAGES_PER_DAY=3
